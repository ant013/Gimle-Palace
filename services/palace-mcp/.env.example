# Neo4j connection
NEO4J_URI=bolt://neo4j:7687
NEO4J_PASSWORD=changeme

# Paperclip ingest credentials (required for ingest CLI only)
PAPERCLIP_API_URL=https://paperclip.ant013.work
PAPERCLIP_INGEST_API_KEY=
PAPERCLIP_COMPANY_ID=

# Namespace for palace-memory data. Default matches the pre-migration
# single-project reality. Change only if you are running multi-project
# ingest.
PALACE_DEFAULT_GROUP_ID=project/gimle

# palace.ops.unstick_issue — SSH host for kill operations.
# host.docker.internal reaches the Mac host from Docker for Mac containers.
# Use imac-ssh.ant013.work for remote/non-Docker-Desktop deployments.
# Use "local" to run kill on the container host directly (testing only).
PALACE_OPS_HOST=host.docker.internal

# Path to the palace-ops SSH private key inside the container.
# Mount via compose: ${HOME}/.ssh/palace_ops_id_ed25519 → this path (ro).
PALACE_OPS_SSH_KEY=/home/appuser/.ssh/palace_ops_id_ed25519
# Paperclip API key for palace.ops.unstick_issue authentication.
PAPERCLIP_API_KEY=

# GIM-182: SCIP index paths for multi-repo bundle ingest.
# JSON map slug -> path-inside-container, e.g.:
# {"uw-ios-app":"/repos-hs/unstoppable-wallet-ios/scip/index.scip","evm-kit":"/repos-hs/EvmKit.Swift/scip/index.scip"}
PALACE_SCIP_INDEX_PATHS={}
