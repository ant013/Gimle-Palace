# Copy to .env and fill in real values before running docker compose up

# Neo4j authentication password (used for NEO4J_AUTH and healthcheck)
# SECURITY: override in production .env, never commit real password. Generated via 'openssl rand -base64 32' recommended.
NEO4J_PASSWORD=changeme

# Graphiti: used by graphiti-core 0.28 constructor (LLM/embedder stubs).
# Writes go via add_triplet — LLM is never invoked, but constructor requires
# a valid client, so the key must be present. Embedder (text-embedding-3-small)
# is invoked via generate_name_embedding() before EntityNode.save (GIM-75 QA).
OPENAI_API_KEY=sk-...

# Git SHA injected into palace-mcp image at build time
PALACE_GIT_SHA=unknown

# Path to codebase-memory-mcp binary inside palace-mcp container (code-graph profile).
# Leave empty (default) — CM subprocess disabled, palace.code.* tools unavailable.
# Set to /usr/local/bin/codebase-memory-mcp to enable:
#   docker compose --profile code-graph up
CODEBASE_MEMORY_MCP_BINARY=

# palace.ops.unstick_issue tool settings
# Set PALACE_OPS_HOST=local to run ps/kill locally without SSH (when palace-mcp
# is on the same machine as paperclip). Otherwise set to SSH hostname.
# host.docker.internal reaches the Mac host from Docker for Mac containers.
PALACE_OPS_HOST=host.docker.internal
# SSH user on the host machine running paperclip processes.
PALACE_OPS_SSH_USER=anton
# Path to the palace-ops SSH private key inside the container.
# Mount via compose: ${HOME}/.ssh/palace_ops_id_ed25519 → this path (ro).
PALACE_OPS_SSH_KEY=/home/appuser/.ssh/palace_ops_id_ed25519
# Paperclip API URL reachable from inside the container.
# PALACE_ prefix avoids collision with host-level PAPERCLIP_API_URL set by paperclip agents.
PALACE_PAPERCLIP_API_URL=http://host.docker.internal:3100
# Paperclip API key for palace.ops.unstick_issue to authenticate against the API.
# Use a long-lived service key or operator's short-lived JWT.
PAPERCLIP_API_KEY=

# JSON map of project slug → SCIP index path (operator generates outside container)
# Path must be the in-container path (i.e., inside a bind-mounted /repos/<slug>).
# gimle: iOS/macOS project; uw-android: Android project (Slice 1 GIM-127);
# uw-ios-mini: committed Swift fixture merge gate; uw-ios: optional real-source follow-up.
PALACE_SCIP_INDEX_PATHS={"gimle":"/repos/gimle/scip/index.scip","oz-v5-mini":"/repos/oz-v5-mini/index.scip","uw-android":"/repos/uw-android/scip/index.scip","uw-ios-mini":"/repos/uw-ios-mini/scip/index.scip","uw-ios":"/repos/uw-ios/scip/index.scip"}
