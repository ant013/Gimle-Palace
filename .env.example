# Copy to .env and fill in real values before running docker compose up

# Neo4j authentication password (used for NEO4J_AUTH and healthcheck)
# SECURITY: override in production .env, never commit real password. Generated via 'openssl rand -base64 32' recommended.
NEO4J_PASSWORD=changeme

# Git SHA injected into palace-mcp image at build time
PALACE_GIT_SHA=unknown
