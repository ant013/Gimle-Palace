# Copy to .env and fill in real values before running docker compose up

# Neo4j authentication password (used for NEO4J_AUTH and healthcheck)
# SECURITY: override in production .env, never commit real password. Generated via 'openssl rand -base64 32' recommended.
NEO4J_PASSWORD=changeme

# Git SHA injected into palace-mcp image at build time
PALACE_GIT_SHA=unknown

# Embedder settings (graphiti-core OpenAIEmbedder via OpenAI-compat endpoint)
# Defaults work for a local Ollama instance — override for DashScope, Voyage, OpenAI, etc.
EMBEDDING_BASE_URL=http://ollama:11434/v1
EMBEDDING_API_KEY=placeholder
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIM=768

# LLM client — required by graphiti-core constructor; not invoked in N+1a ingest.
# Leave blank to fall back to EMBEDDING_BASE_URL/EMBEDDING_API_KEY.
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=llama3:8b
