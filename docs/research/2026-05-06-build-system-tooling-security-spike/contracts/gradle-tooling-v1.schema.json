{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gimle.dev/contracts/build-system/gradle-tooling-v1.schema.json",
  "title": "Gradle tooling v1 sample",
  "type": "object",
  "required": [
    "schema_version",
    "tool_name",
    "tool_version",
    "root_path",
    "projects",
    "tasks"
  ],
  "properties": {
    "schema_version": {
      "const": "gradle-tooling-v1"
    },
    "tool_name": {
      "const": "gradle"
    },
    "tool_version": {
      "type": "string",
      "minLength": 1
    },
    "capture_mode": {
      "type": "string"
    },
    "root_path": {
      "type": "string",
      "minLength": 1
    },
    "projects": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "path",
          "name",
          "project_dir"
        ],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "project_dir": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "path",
          "name",
          "owner_project"
        ],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "owner_project": {
            "type": "string",
            "minLength": 1
          },
          "group": {
            "type": [
              "string",
              "null"
            ]
          },
          "description": {
            "type": [
              "string",
              "null"
            ]
          },
          "dependencies": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
