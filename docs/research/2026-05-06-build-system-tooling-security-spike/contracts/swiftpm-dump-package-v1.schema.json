{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gimle.dev/contracts/build-system/swiftpm-dump-package-v1.schema.json",
  "title": "SwiftPM dump-package v1 sample",
  "type": "object",
  "required": [
    "schema_version",
    "tool_name",
    "tool_version",
    "package_root",
    "package"
  ],
  "properties": {
    "schema_version": {
      "const": "swiftpm-dump-package-v1"
    },
    "tool_name": {
      "const": "swift"
    },
    "tool_version": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160
    },
    "capture_mode": {
      "type": "string"
    },
    "package_root": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    },
    "package": {
      "type": "object",
      "required": [
        "name",
        "products",
        "targets"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "products": {
          "type": "array",
          "minItems": 1,
          "maxItems": 32,
          "items": {
            "type": "object",
            "required": [
              "name",
              "targets"
            ],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1,
                "maxLength": 128
              },
              "targets": {
                "type": "array",
                "minItems": 1,
                "maxItems": 16,
                "items": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 128
                }
              },
              "type": {
                "type": "object",
                "properties": {
                  "library": {
                    "type": "array",
                    "maxItems": 4,
                    "items": {
                      "type": "string",
                      "maxLength": 32
                    }
                  },
                  "executable": {
                    "type": [
                      "string",
                      "null"
                    ],
                    "maxLength": 32
                  }
                }
              }
            }
          }
        },
        "targets": {
          "type": "array",
          "minItems": 1,
          "maxItems": 64,
          "items": {
            "type": "object",
            "required": [
              "name",
              "dependencies"
            ],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1,
                "maxLength": 128
              },
              "type": {
                "type": "string",
                "minLength": 1,
                "maxLength": 32
              },
              "dependencies": {
                "type": "array",
                "maxItems": 16,
                "items": {
                  "type": "object",
                  "properties": {
                    "byName": {
                      "type": "array",
                      "minItems": 2,
                      "maxItems": 2,
                      "items": {
                        "type": [
                          "string",
                          "null"
                        ],
                        "maxLength": 128
                      }
                    }
                  }
                }
              },
              "resources": {
                "type": "array",
                "maxItems": 16,
                "items": {
                  "type": "object",
                  "required": [
                    "rule",
                    "path"
                  ],
                  "properties": {
                    "rule": {
                      "type": "string",
                      "minLength": 1,
                      "maxLength": 32
                    },
                    "path": {
                      "type": "string",
                      "minLength": 1,
                      "maxLength": 256
                    }
                  }
                }
              },
              "settings": {
                "type": "array",
                "maxItems": 16,
                "items": {
                  "type": "object",
                  "required": [
                    "tool",
                    "name",
                    "value"
                  ],
                  "properties": {
                    "tool": {
                      "type": "string",
                      "minLength": 1,
                      "maxLength": 32
                    },
                    "name": {
                      "type": "string",
                      "minLength": 1,
                      "maxLength": 64
                    },
                    "value": {
                      "type": "string",
                      "minLength": 1,
                      "maxLength": 128
                    }
                  }
                }
              }
            }
          }
        },
        "toolsVersion": {
          "type": [
            "object",
            "null"
          ]
        }
      }
    }
  }
}
