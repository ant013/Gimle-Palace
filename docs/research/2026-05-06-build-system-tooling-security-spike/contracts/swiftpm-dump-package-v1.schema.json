{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gimle.dev/contracts/build-system/swiftpm-dump-package-v1.schema.json",
  "title": "SwiftPM dump-package v1 sample",
  "type": "object",
  "required": [
    "schema_version",
    "tool_name",
    "tool_version",
    "package_root",
    "package"
  ],
  "properties": {
    "schema_version": {
      "const": "swiftpm-dump-package-v1"
    },
    "tool_name": {
      "const": "swift"
    },
    "tool_version": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160
    },
    "capture_mode": {
      "type": "string"
    },
    "package_root": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    },
    "package": {
      "type": "object",
      "required": [
        "name",
        "products",
        "targets"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "products": {
          "type": "array",
          "minItems": 1,
          "maxItems": 32
        },
        "targets": {
          "type": "array",
          "minItems": 1,
          "maxItems": 64
        },
        "toolsVersion": {
          "type": [
            "object",
            "null"
          ]
        }
      }
    }
  }
}
